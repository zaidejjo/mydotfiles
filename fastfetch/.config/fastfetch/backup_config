{
"$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
"logo": {
    "source": "linux_small", // شعار البطريق الصغير
    "type": "small",
    "padding": {
        "top": 1,
        "left": 2
    },
    "color": {
        "1": "magenta", // لون ناعم قريب من Catppuccin
        "2": "blue"
    }
},
"display": {
    "separator": " ",
    "color": {
        "keys": "magenta",   // لون المفاتيح (Pink/Magenta)
        "title": "blue"      // لون الاسم (Sapphire)
    }
},
"modules": [
    {
        "type": "title",
        "format": "{user-name}@{host-name}"
    },
    {
        "type": "os",
        "key": "󰣇 OS", // أيقونات لطيفة
        "keyColor": "blue"
    },
    {
        "type": "kernel",
        "key": " KN",
        "keyColor": "magenta"
    },
    {
        "type": "uptime",
        "key": "󱎫 UP",
        "keyColor": "yellow"
    },
    {
        "type": "memory",
        "key": "󰍛 MEM",
        "keyColor": "green"
    },
    "break",
    {
        "type": "colors",
        "symbol": "circle" // دوائر الألوان بدل المربعات
    }
]
}
